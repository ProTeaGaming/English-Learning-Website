DJANGO_SECRET_KEY=change-me-to-a-long-random-string
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=youraccount@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx
FROM_EMAIL=youraccount@gmail.com
FROM_NAME=VocabLarry
APP_BASE_URL=http://localhost:8000

# Social login — get credentials from each platform's developer console,
# then register this exact callback URL there (swap the domain once you
# have a real host): http://localhost:8000/accounts/<provider>/login/callback/
# e.g. http://localhost:8000/accounts/google/login/callback/

# Google Cloud Console -> APIs & Services -> Credentials -> OAuth client ID
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Meta for Developers -> your app -> Facebook Login -> Settings
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# GitHub -> Settings -> Developer settings -> OAuth Apps
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Microsoft Entra admin center -> App registrations -> your app
# -> Certificates & secrets (client secret) / Overview (application ID)
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
# 'common' = any Microsoft account (personal + work/school); only change
# this to a tenant ID if you want to restrict sign-in to one organization.
MICROSOFT_TENANT=common

# Apple Developer (requires a paid Apple Developer Program membership)
# -> Certificates, Identifiers & Profiles:
#   APPLE_TEAM_ID     = Membership -> Team ID
#   APPLE_CLIENT_ID   = Identifiers -> your Services ID (not the App ID)
#   APPLE_KEY_ID      = Keys -> the key you create with "Sign In with Apple" enabled
#   APPLE_PRIVATE_KEY = paste the full contents of the downloaded .p8 file,
#                       including the -----BEGIN/END PRIVATE KEY----- lines
APPLE_TEAM_ID=
APPLE_CLIENT_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=
